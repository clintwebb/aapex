<VirtualHost {{ shyweb_webiress_url }}:443>
  DocumentRoot "/opt/www/sites/generic/docs"
  ServerName  {{ shyweb_webiress_url }}
  #ServerAlias webiress.onlineinvesting.westpac.com.au
  ServerAdmin wmaster@broking.westpac.com.au
  ErrorLog        /var/log/httpd/webiress-error_log
  CustomLog       /var/log/httpd/webiress-access_log shy-audit env=!forwarded
  CustomLog       /var/log/httpd/webiress-access_log shy-audit-proxy env=forwarded
  <Directory /opt/www/sites/>
    Require all granted
  </Directory>
  ProxyRequests On
  ProxyPass /error/      !
  ProxyPass /jmx-console !
  ProxyPass /             balancer://webiress_cluster/ nofailover=On
  ProxyPassReverse /      balancer://webiress_cluster/ nofailover=On
  <Proxy balancer://webiress_cluster>
    BalancerMember http://appserver-1:9680
    BalancerMember http://appserver-2:9680
    ProxySet lbmethod=byrequests
  </Proxy>
  SSLEngine on
  SSLCipherSuite ALL:!ADH:!EXPORT56:RC4+RSA:+HIGH:+MEDIUM:+LOW:+SSLv2:+EXP:+eNULL
  SSLCertificateFile /opt/www/etc/ssl/certs/{{ shyweb_webiress_url }}.crt
  SSLCertificateKeyFile /opt/www/etc/ssl/private/{{ shyweb_webiress_url }}.key
  SSLCACertificateFile /opt/www/etc/ssl/certs/CA.crt
  <Files ~ "\.(cgi|shtml|phtml|php3?)$">
    SSLOptions +StdEnvVars
  </Files>
  <Directory "/usr/local/apache/cgi-bin">
    SSLOptions +StdEnvVars
  </Directory>
  SetEnvIf User-Agent ".*MSIE.*" nokeepalive ssl-unclean-shutdown downgrade-1.0 force-response-1.0
  ErrorDocument 403 /error/maintenance.html
  ErrorDocument 404 /error/maintenance.html
</VirtualHost>
